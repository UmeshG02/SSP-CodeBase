datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  SUPER_ADMIN
  ADMIN
  CONTENT_MANAGER
  MODERATOR
  SUPPORT_STAFF
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ChallengeType {
  CODING
  SQL
  APTITUDE
  INTERVIEW
  PUZZLE
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  passwordHash   String?
  role           Role           @default(USER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  profile        Profile?
  submissions    Submission[]
  xpTransactions XPTransaction[]
  streaks        Streak?
  badges         UserBadge[]
  friendshipsSent Friendship[]   @relation("FriendshipsSent")
  friendshipsRecv Friendship[]   @relation("FriendshipsReceived")
  teamMembers    TeamMember[]
  discussions    Discussion[]
  comments       Comment[]
  likes          Like[]
  learningProgress UserProgress[]
  dayProgress      UserDayProgress[]
  violationLogs    ViolationLog[]
  assessmentSessions AssessmentSession[]
  securityEvents     SecurityEvent[]
}

model Profile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  username     String   @unique
  avatarUrl    String?
  college      String?
  company      String?
  skills       String[] // e.g., ["React", "TypeScript", "Node.js"]
  prefLang     String   @default("Python")
  expLevel     String   @default("Beginner") // Beginner, Intermediate, Expert
  xp           Int      @default(0)
  coins        Int      @default(0)
  level        Int      @default(1)
  rank         Int?
}

model Problem {
  id           String        @id @default(uuid())
  title        String
  slug         String        @unique
  description  String        @db.Text
  difficulty   Difficulty    @default(EASY)
  type         ChallengeType @default(CODING)
  points       Int           @default(10)
  tags         String[]
  inputFormat  String?       @db.Text
  outputFormat String?       @db.Text
  constraints  String?       @db.Text
  templateCode String?       @db.Text // JSON map containing templates for different languages
  solutionCode String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  testCases    TestCase[]
  submissions  Submission[]
  comments     Comment[]
  violationLogs   ViolationLog[]
  assessmentSessions AssessmentSession[]
  dayId            String?
  day              Day?              @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model TestCase {
  id           String   @id @default(uuid())
  problemId    String
  problem      Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  input        String   @db.Text
  expected     String   @db.Text
  isSample     Boolean  @default(false)
}

model Submission {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId  String
  problem    Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  language   String
  code       String   @db.Text
  status           String   // e.g. "ACCEPTED", "WRONG_ANSWER", "RUNTIME_ERROR", "COMPILE_ERROR"
  runtime          Float?   // in ms
  memory           Float?   // in KB
  autoSubmitted    Boolean  @default(false)
  autoSubmitReason String?  @db.Text
  createdAt        DateTime @default(now())
}

model Streak {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak Int     @default(0)
  longestStreak Int     @default(0)
  lastActive   DateTime @default(now())
}

model Badge {
  id          String      @id @default(uuid())
  name        String      @unique
  description String
  imageUrl    String
  users       UserBadge[]
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt  DateTime @default(now())
}

model XPTransaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String   // e.g. "DAILY_CHALLENGE", "STREAK_BONUS"
  createdAt DateTime @default(now())
}

model Friendship {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("FriendshipsSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("FriendshipsReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  status     String   // "PENDING", "ACCEPTED", "REJECTED"
  createdAt  DateTime @default(now())
}

model Team {
  id        String       @id @default(uuid())
  name      String       @unique
  avatarUrl String?
  createdAt DateTime     @default(now())
  members   TeamMember[]
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   // "LEADER", "MEMBER"
  joinedAt  DateTime @default(now())
}

model Discussion {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String    @db.Text
  tags      String[]
  createdAt DateTime  @default(now())
  comments  Comment[]
}

model Comment {
  id           String      @id @default(uuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId    String?
  problem      Problem?    @relation(fields: [problemId], references: [id], onDelete: Cascade)
  discussionId String?
  discussion   Discussion? @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  content      String      @db.Text
  createdAt    DateTime    @default(now())
  likes        Like[]
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model LearningPath {
  id          String         @id @default(uuid())
  title       String
  description String         @db.Text
  slug        String         @unique
  weeks       Week[]
  progress    UserProgress[]
}

model Week {
  id         String       @id @default(uuid())
  pathId     String
  path       LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  title      String
  weekNumber Int
  days       Day[]
  accessKey  String?
}

model Day {
  id           String            @id @default(uuid())
  weekId       String
  week         Week              @relation(fields: [weekId], references: [id], onDelete: Cascade)
  title        String
  dayNumber    Int
  objectives   String[]
  problems     Problem[]
  userProgress UserDayProgress[]
}

model UserProgress {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pathId        String
  path          LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  currentWeek   Int          @default(1)
  currentDay    Int          @default(1)
  unlockedWeeks Int[]

  @@unique([userId, pathId])
}

model UserDayProgress {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayId       String
  day         Day       @relation(fields: [dayId], references: [id], onDelete: Cascade)
  completed   Boolean   @default(false)
  completedAt DateTime?
  timeSpent   Int       @default(0)
  xpEarned    Int       @default(0)
  accuracy    Float     @default(0.0)
  score       Int       @default(0)

  @@unique([userId, dayId])
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  adminEmail String
  action     String   // e.g. "USER_CREATE", "PROGRESS_UNLOCK", "CONTENT_EDIT"
  details    String   @db.Text
  createdAt  DateTime @default(now())
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())
  authorId  String
}

model SupportRequest {
  id        String   @id @default(uuid())
  userId    String?
  name      String
  email     String
  subject   String
  message   String   @db.Text
  status    String   @default("PENDING") // "PENDING", "IN_PROGRESS", "RESOLVED"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExamConfig {
  id                    String   @id @default(uuid())
  maxViolations         Int      @default(3)
  fullscreenEnabled     Boolean  @default(true)
  tabSwitchEnabled      Boolean  @default(true)
  copyPasteDisabled     Boolean  @default(true)
  rightClickDisabled    Boolean  @default(true)
  devToolsDisabled      Boolean  @default(true)
  resizeWarningsEnabled Boolean  @default(true)
  autoSaveEnabled       Boolean  @default(true)
  autoSaveInterval      Int      @default(15)
  windowFocusDetection  Boolean  @default(true)
  enforceFullScreen     Boolean  @default(true)
  lockDurationMinutes   Int      @default(30)
  availableLockDurations Int[]   @default([10, 15, 30, 60])
  violationResetPolicy  String   @default("AFTER_ASSESSMENT")
  warningMsg1           String   @default("Warning 1 of 3: You have left the exam window. Please return immediately.")
  warningMsg2           String   @default("Warning 2 of 3: One more violation will automatically submit your assessment.")
  warningMsg3           String   @default("Your assessment has been automatically submitted because the maximum number of security violations was reached.")
  updatedAt             DateTime @updatedAt
}

model AssessmentSession {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId       String
  problem         Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)
  status          String    @default("ACTIVE")
  startTime       DateTime  @default(now())
  endTime         DateTime?
  violationCount  Int       @default(0)
  maxViolations   Int       @default(3)
  lockDuration    Int       @default(30)
  lockedAt        DateTime?
  unlocksAt       DateTime?
  currentCode     String?   @db.Text
  currentLanguage String?
  currentQuestion Int       @default(0)
  totalQuestions  Int       @default(1)
  timeSpent       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  violationLogs   ViolationLog[]
  lockHistory     LockHistory[]
  autoSaves       AutoSave[]

  @@unique([userId, problemId, status])
}

model ViolationLog {
  id                 String             @id @default(uuid())
  userId             String
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId          String
  problem            Problem            @relation(fields: [problemId], references: [id], onDelete: Cascade)
  sessionId          String?
  session            AssessmentSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  violationType      String
  details            String?            @db.Text
  totalCount         Int
  browser            String
  os                 String
  ipAddress          String?
  assessmentDuration Int?
  remainingTime      Int?
  lockStatus         String?
  module             String?
  day                String?
  questionNumber     Int?
  createdAt          DateTime           @default(now())
}

model LockHistory {
  id           String             @id @default(uuid())
  sessionId    String
  session      AssessmentSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  lockedAt     DateTime           @default(now())
  scheduledUnlockAt DateTime?
  unlockedAt   DateTime?
  unlockReason String?
  duration     Int                @default(30)
  createdBy    String?            @default("SYSTEM")
  createdAt    DateTime           @default(now())
}

model AutoSave {
  id             String             @id @default(uuid())
  sessionId      String
  session        AssessmentSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  code           String             @db.Text
  language       String?
  questionNumber Int?
  questionType   String?
  metadata       String?            @db.Text
  createdAt      DateTime           @default(now())
}

model SecurityEvent {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action        String
  details       String?  @db.Text
  ipAddress     String?
  userAgent     String?
  metadata      String?  @db.Text
  createdAt     DateTime @default(now())
}

